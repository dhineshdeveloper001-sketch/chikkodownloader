generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(uuid())
  name          String
  email         String     @unique
  password_hash String
  role          String     @default("user") // "user" or "admin"
  created_at    DateTime   @default(now())
  downloads     Download[]
  auditLogs     AuditLog[]

  @@map("users")
}

model Download {
  id            String   @id @default(uuid())
  user_id       String
  original_url  String
  file_name     String
  file_type     String
  file_size     BigInt
  download_date DateTime @default(now())
  status        String   @default("completed") // "downloading", "completed", "error"

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([download_date(sort: Desc)])
  @@map("downloads")
}

model DownloadStat {
  id                 String   @id @default(uuid())
  total_downloads    Int      @default(0)
  total_storage_used BigInt   @default(0)
  updated_at         DateTime @updatedAt

  @@map("download_stats")
}

model AuditLog {
  id         String   @id @default(uuid())
  user_id    String?  // nullable for anonymous/system actions
  action     String   // e.g. "LOGIN", "REGISTER", "DOWNLOAD_START"
  details    String?  // JSON string or simple text describing the action
  created_at DateTime @default(now())

  user       User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([created_at(sort: Desc)])
  @@map("audit_logs")
}

model VideoCache {
  id          String   @id @default(uuid())
  videoId     String   @unique @map("video_id")
  title       String?
  thumbnail   String?
  duration    Int?
  uploader    String?
  viewCount   BigInt?  @map("view_count")
  metadata    Json     // Basic metadata (title, views, etc)
  formats     Json     // Large array of video/audio formats
  isNegative  Boolean  @default(false) @map("is_negative") // True if video is private/unavailable
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([videoId])
  @@index([expiresAt])
  @@map("video_cache")
}
