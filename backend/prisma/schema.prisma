generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String            @id @default(uuid())
  username       String            @unique
  passwordHash   String            @map("password_hash")
  role           String            @default("USER")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  lastLogin      DateTime?         @map("last_login")
  failedAttempts Int               @default(0) @map("failed_attempts")
  lockedUntil    DateTime?         @map("locked_until")
  isActive       Boolean           @default(true) @map("is_active")
  
  downloads      DownloadHistory[]
  auditLogs      AuditLog[]

  @@map("users")
}

model DownloadHistory {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  platform     String
  url          String
  title        String
  thumbnail    String?
  status       String   @default("completed") // "downloading", "completed", "error"
  downloadTime DateTime @default(now()) @map("download_time")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([downloadTime(sort: Desc)])
  @@map("download_history")
}

model DownloadStat {
  id                 String   @id @default(uuid())
  total_downloads    Int      @default(0)
  total_storage_used BigInt   @default(0)
  updated_at         DateTime @updatedAt

  @@map("download_stats")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String   
  details    String?  
  createdAt  DateTime @default(now()) @map("created_at")

  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

model VideoCache {
  id          String   @id @default(uuid())
  videoId     String   @unique @map("video_id")
  title       String?
  thumbnail   String?
  duration    Int?
  uploader    String?
  viewCount   BigInt?  @map("view_count")
  metadata    Json     // Basic metadata (title, views, etc)
  formats     Json     // Large array of video/audio formats
  isNegative  Boolean  @default(false) @map("is_negative") // True if video is private/unavailable
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([videoId])
  @@index([expiresAt])
  @@map("video_cache")
}
